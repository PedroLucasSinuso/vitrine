# ──────────────────────────────────────────────
# INFRAESTRUTURA (obrigatório — manter sempre)
# ──────────────────────────────────────────────
SQLITE_URL=sqlite:///./data/price_checker.db
JWT_SECRET=sua-chave-secreta-grande-e-aleatoria

# URLs permitidas para CORS (frontend)
ALLOWED_ORIGINS=["http://localhost:5173"]

# Chave para criptografar senhas de configurações sensíveis no banco
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ERPS_ENCRYPTION_KEY=
ALLOW_ORIGIN_REGEX=https://.*\.trycloudflare\.com

# ──────────────────────────────────────────────
# CONFIGURAÇÕES OPERACIONAIS (opcional)
# ──────────────────────────────────────────────
# Estas variáveis foram migradas para a tela de Admin > Configurações.
# Se estiverem preenchidas aqui, o sistema as copia automaticamente
# para o banco na primeira execução. Depois de configuradas pela UI,
# os valores no .env são ignorados.
#
# POSTGRES_URL=postgresql://usuario:senha@host:5432/banco
# POSTGRES_HOST=host
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=banco
# POSTGRES_USER=usuario
# POSTGRES_PASSWORD=senha
# CACHE_REFRESH_INTERVAL=3600
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
